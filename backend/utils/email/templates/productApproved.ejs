<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Product Approved</title>
</head>

<body
  style="
    margin: 0;
    padding: 0;
    background-color: #f4f6f8;
    font-family: Arial, sans-serif;
  "
>
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding: 40px 20px">
        <table
          width="600"
          cellpadding="0"
          cellspacing="0"
          style="
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
          "
        >
          <!-- HEADER -->
          <tr>
            <td
              align="center"
              style="
                background: #111827;
                padding: 30px;
                color: white;
              "
            >
              <h1 style="margin: 0">Rubber Scrap Mart</h1>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="padding: 40px 30px">
              <h2 style="margin-top: 0; color: #16a34a">
                Product Approved ✅
              </h2>

              <p>Hello <%= sellerName %>,</p>

              <p>
                Your product
                <strong><%= productName %></strong>
                has been approved by the admin team.
              </p>

              <p>
                It is now visible to buyers on Rubber Scrap Mart marketplace.
              </p>

              <div style="margin: 30px 0">
                <a
                  href="https://rubberscrapmart.com"
                  style="
                    background: #16a34a;
                    color: white;
                    padding: 14px 24px;
                    text-decoration: none;
                    border-radius: 8px;
                    display: inline-block;
                  "
                >
                  View Marketplace
                </a>
              </div>

              <p>
                Thank you for selling with Rubber Scrap Mart.
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td
              align="center"
              style="
                padding: 20px;
                background: #f3f4f6;
                color: #6b7280;
                font-size: 14px;
              "
            >
              © 2026 Rubber Scrap Mart. All rights reserved.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>