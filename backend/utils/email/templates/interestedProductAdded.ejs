<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>New Interested Product Added</title>
</head>

<body
  style="
    margin: 0;
    padding: 0;
    background-color: #f4f6f8;
    font-family: Arial, sans-serif;
  "
>
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding: 40px 20px">
        <table
          width="600"
          cellpadding="0"
          cellspacing="0"
          style="
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
          "
        >
          <!-- HEADER -->

          <tr>
            <td
              align="center"
              style="
                background: #111827;
                padding: 30px;
                color: white;
              "
            >
              <h1 style="margin: 0">
                Rubber Scrap Mart
              </h1>
            </td>
          </tr>

          <!-- CONTENT -->

          <tr>
            <td style="padding: 40px 30px">
              <h2
                style="
                  margin-top: 0;
                  color: #7e22ce;
                "
              >
                New Product Added 🚀
              </h2>

              <p>
                Hello
                <strong>
                  <%= userName %>
                </strong>,
              </p>

              <p>
                A new product matching your
                interests has been added to
                Rubber Scrap Mart marketplace.
              </p>

              <div
                style="
                  background: #f9fafb;
                  padding: 20px;
                  border-radius: 10px;
                  margin: 25px 0;
                "
              >
                <p
                  style="
                    margin: 0 0 10px 0;
                    color: #6b7280;
                  "
                >
                  Product Name
                </p>

                <h3
                  style="
                    margin: 0;
                    color: #111827;
                  "
                >
                  <%= productName %>
                </h3>
              </div>

              <div style="margin: 30px 0">
                <a
                  href="<%= productLink %>"
                  style="
                    background: #7e22ce;
                    color: white;
                    padding: 14px 24px;
                    text-decoration: none;
                    border-radius: 8px;
                    display: inline-block;
                    font-weight: bold;
                  "
                >
                  View Product
                </a>
              </div>

              <p>
                Thank you for using Rubber
                Scrap Mart.
              </p>
            </td>
          </tr>

          <!-- FOOTER -->

          <tr>
            <td
              align="center"
              style="
                padding: 20px;
                background: #f3f4f6;
                color: #6b7280;
                font-size: 14px;
              "
            >
              © 2026 Rubber Scrap Mart.
              All rights reserved.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>